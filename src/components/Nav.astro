---
const path = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/research/', label: 'Research' },
  { href: '/teaching/', label: 'Teaching' },
  { href: '/cv/', label: 'CV' },
];
const isCurrent = (href: string) =>
  path === href || (href !== '/' && path.startsWith(href));
---

<header class="site-nav">
  <div class="inner">
    <a class="nav-name" href="/">Carey Manwa</a>
    <nav class="nav-links" aria-label="Primary">
      {
        links.map((l) => (
          <a href={l.href} aria-current={isCurrent(l.href) ? 'page' : undefined}>
            {l.label}
          </a>
        ))
      }
      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle dark mode"
        title="Toggle theme"
      >
        <svg class="icon-moon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path
            d="M13.5 9.5A6 6 0 0 1 6.5 2.5a6 6 0 1 0 7 7Z"
            stroke="currentColor"
            stroke-width="1.3"
            stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-sun" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.3"
          ></circle>
          <path
            d="M8 1v1.8M8 13.2V15M15 8h-1.8M2.8 8H1m11.4-4.4-1.3 1.3M4.9 11.1l-1.3 1.3m9.8 0-1.3-1.3M4.9 4.9 3.6 3.6"
            stroke="currentColor"
            stroke-width="1.3"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const dark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', dark ? 'dark' : 'light');
    // let the hero canvas re-read its palette
    window.dispatchEvent(new CustomEvent('themechange'));
  });
</script>
