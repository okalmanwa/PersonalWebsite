---
---

<div class="hero">
  <canvas class="hero-canvas" id="sim" aria-hidden="true"></canvas>
  <div class="hero-fade" aria-hidden="true"></div>
  <div class="hero-content">
    <div class="hero-text">
      <h1 class="rise"><span id="typed-name">Carey Okal</span><span
          class="type-caret"
          aria-hidden="true"></span></h1>
      <p class="hero-bio rise">
        I'm an MPS student in Information Science at Cornell Bowers CIS (B.S.
        Information Science '26, cum laude), working at the intersection of
        LLMs, social simulation, and data science. At the
        <a href="/research/social-simulation/">Social Dynamics Lab</a> I audit
        multi-agent LLM simulations and built the large-scale ingestion
        pipelines behind persuasion-strategy research on political news; at
        <a href="/research/disaster-resilience/">CIDER</a> I'm co-authoring a
        white paper on predictive systems for disaster resilience. Before
        Cornell, I worked with EducationUSA in Nairobi, reaching 20,000
        students across 30 Kenyan high schools.
      </p>
    </div>
    <figure class="hero-fig rise">
      <img
        src="/images/portrait.jpg"
        alt="Carey Okal"
        width="768"
        height="1024"
        fetchpriority="high"
      />
    </figure>
  </div>
</div>

<script>
  // 3d fold: hero tips backward on scroll
  (() => {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const hero = document.querySelector('.hero') as HTMLElement | null;
    const content = document.querySelector('.hero-content') as HTMLElement | null;
    if (!hero || !content) return;
    const small = matchMedia('(max-width: 820px)');
    const reset = () => { content.style.transform = ''; content.style.opacity = ''; content.style.filter = ''; };
    small.addEventListener('change', () => { if (small.matches) reset(); });
    let ticking = false;
    const update = () => {
      ticking = false;
      if (small.matches) { reset(); return; }
      const h = hero.offsetHeight || 1;
      const p = Math.min(Math.max(window.scrollY / (h * 0.9), 0), 1);
      content.style.transform = `rotateX(${(-58 * p).toFixed(2)}deg) scale(${(1 - 0.16 * p).toFixed(3)}) translateY(${(-26 * p).toFixed(1)}px)`;
      content.style.opacity = (1 - 0.92 * p).toFixed(3);
      content.style.filter = p > 0.01 ? `blur(${(3.5 * p).toFixed(2)}px)` : '';
    };
    window.addEventListener('scroll', () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } }, { passive: true });
    update();
  })();

  // Typewriter
  (() => {
    const el = document.getElementById('typed-name');
    if (!el || matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const name = el.textContent ?? '';
    el.textContent = '';
    const caret = document.querySelector('.type-caret') as HTMLElement | null;
    let at = 0;
    function type() {
      el!.textContent = name.slice(0, ++at);
      if (at < name.length) setTimeout(type, 95 + Math.random() * 70);
      else if (caret) setTimeout(() => caret.classList.add('type-caret--done'), 2100);
    }
    setTimeout(type, 500);
  })();

  // ── Suminagashi rings ─────────────────────────────────────────────────────
  // Concentric hairline rings spread from a few drop points, like ink rings
  // on still water. Three layers of life:
  //   · depth — inner rings ink darker, fading toward the rim
  //   · ripples — every few seconds a red wave radiates out through a system,
  //     swelling and tinting the rings it passes, like a fresh drop landing
  //   · the cursor — rings light up as it nears them, and movement drags the
  //     lines aside like a stylus through the water before they relax back
  (() => {
    const canvas = document.getElementById('sim') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fine = matchMedia('(hover: hover) and (pointer: fine)').matches;

    // ── sizing ──
    let W = 0, H = 0, dpr = 1;
    function resize() {
      const r = canvas.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = r.width; H = r.height;
      canvas.width  = Math.round(W * dpr);
      canvas.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    let rt: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => { resize(); if (reduced) draw(0); }, 150);
    });

    // ── palette ──
    let ink = '#121216', accent = '#9a1414';
    let inkRgb = [18, 18, 22], accentRgb = [154, 20, 20];
    function hexRgb(h: string): number[] {
      h = h.trim().replace('#', '');
      if (h.length === 3) h = h.split('').map((c) => c + c).join('');
      const n = parseInt(h, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }
    function readColors() {
      const s = getComputedStyle(document.documentElement);
      ink    = s.getPropertyValue('--ink').trim()    || ink;
      accent = s.getPropertyValue('--accent').trim() || accent;
      inkRgb = hexRgb(ink);
      accentRgb = hexRgb(accent);
    }
    function towardAccent(f: number): string {
      const r = Math.round(inkRgb[0] + (accentRgb[0] - inkRgb[0]) * f);
      const g = Math.round(inkRgb[1] + (accentRgb[1] - inkRgb[1]) * f);
      const b = Math.round(inkRgb[2] + (accentRgb[2] - inkRgb[2]) * f);
      return `rgb(${r},${g},${b})`;
    }
    readColors();
    window.addEventListener('themechange', () => { readColors(); if (reduced) draw(0); });

    // ── drop systems ──
    const drops = [
      {
        ax: 0.70, ay: 0.42, gap: 30, rings: 42, accentRing: 7,
        h: [{ k: 3, a: 0.028, p: 1.7 }, { k: 5, a: 0.016, p: 4.2 }],
      },
      {
        ax: 0.16, ay: 0.80, gap: 26, rings: 13, accentRing: 4,
        h: [{ k: 4, a: 0.030, p: 0.6 }, { k: 7, a: 0.014, p: 2.9 }],
      },
      {
        ax: 0.38, ay: 0.10, gap: 24, rings: 9, accentRing: -1,
        h: [{ k: 3, a: 0.026, p: 5.1 }, { k: 6, a: 0.015, p: 1.3 }],
      },
    ];

    // ── ripples: a wave radiates out from each centre on its own clock ──
    const ripples = drops.map((d, i) => ({
      at: performance.now() + 1400 + i * 3400,
      speed: 150 + i * 20, // px per second
    }));

    // ── stylus impulses ──
    interface Imp { x: number; y: number; dx: number; dy: number; born: number }
    const imps: Imp[] = [];
    const SIGMA = 90, SIG2 = 2 * SIGMA * SIGMA, TAU = 1200, MAX_IMPS = 14;

    let lastX = -1, lastY = -1;   // previous pointer sample (for deltas)
    let curX = -1, curY = -1;     // live pointer position (for the glow)
    const hero = canvas.closest('.hero') as HTMLElement | null;
    if (!reduced && fine && hero) {
      hero.addEventListener('pointermove', (e: PointerEvent) => {
        const r = hero.getBoundingClientRect();
        const x = e.clientX - r.left, y = e.clientY - r.top;
        curX = x; curY = y;
        if (lastX >= 0) {
          let dx = x - lastX, dy = y - lastY;
          const sp = Math.hypot(dx, dy);
          if (sp < 3) return;
          const cap = Math.min(sp, 24) / sp;
          dx *= cap * 1.55; dy *= cap * 1.55;
          imps.push({ x, y, dx, dy, born: performance.now() });
          if (imps.length > MAX_IMPS) imps.shift();
        }
        lastX = x; lastY = y;
      }, { passive: true });
      hero.addEventListener('pointerleave', () => {
        lastX = -1; lastY = -1; curX = -1; curY = -1;
      });
    }

    // ── draw ──
    function draw(t: number) {
      ctx.clearRect(0, 0, W, H);
      const now = performance.now();

      for (let i = imps.length - 1; i >= 0; i--) {
        if (now - imps[i].born > TAU * 4) imps.splice(i, 1);
      }

      for (let di = 0; di < drops.length; di++) {
        const d = drops[di];
        const cx = d.ax * W, cy = d.ay * H;
        const maxR = d.rings * d.gap;

        // where is this system's ripple right now?
        const rp = ripples[di];
        let rippleR = -1;
        if (!reduced && now >= rp.at) {
          rippleR = ((now - rp.at) / 1000) * rp.speed;
          if (rippleR > maxR + 150) {
            rp.at = now + 2600 + Math.random() * 3200;
            rippleR = -1;
          }
        }

        // cursor distance to this centre (for the proximity glow)
        const dc = curX >= 0 ? Math.hypot(curX - cx, curY - cy) : -1;

        for (let ri = 1; ri <= d.rings; ri++) {
          const r0 = ri * d.gap;

          // depth: strong heart, whispering rim
          let a = 0.225 - (r0 / maxR) * 0.145;
          if (ri % 5 === 0) a += 0.05;

          // the ring nearest the cursor catches the light
          if (dc >= 0) {
            const dd = Math.abs(dc - r0);
            if (dd < 80) a += 0.2 * (1 - dd / 80) ** 2;
          }

          // the passing wave: swell, brighten, blush red
          let g = 0;
          if (rippleR >= 0) {
            const dr = Math.abs(r0 - rippleR);
            if (dr < 130) g = Math.exp(-(dr * dr) / 3872); // 2·44²
          }
          a += 0.26 * g;

          const isAccent = ri === d.accentRing;
          if (isAccent) {
            ctx.strokeStyle = accent;
            a = Math.max(a, 0.26);
          } else {
            ctx.strokeStyle = g > 0.04 ? towardAccent(Math.min(1, g * 0.85)) : ink;
          }
          ctx.globalAlpha = Math.min(a, 0.5);
          ctx.lineWidth = 1 + 0.7 * g;

          const rBase = r0 + 7 * g; // the wave lifts the ring as it passes
          const segs = Math.min(220, Math.max(56, (r0 * 0.55) | 0));

          ctx.beginPath();
          for (let s = 0; s <= segs; s++) {
            const th = (s / segs) * Math.PI * 2;

            let r = rBase;
            for (const hm of d.h) {
              r += Math.sin(hm.k * th + hm.p + t * 0.00008 * hm.k) * r0 * hm.a;
            }

            let px = cx + Math.cos(th) * r;
            let py = cy + Math.sin(th) * r;

            for (const im of imps) {
              const ddx = px - im.x, ddy = py - im.y;
              if (ddx > 280 || ddx < -280 || ddy > 280 || ddy < -280) continue;
              const w =
                Math.exp(-(ddx * ddx + ddy * ddy) / SIG2) *
                Math.exp(-(now - im.born) / TAU);
              px += im.dx * w;
              py += im.dy * w;
            }

            s === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
          }
          ctx.stroke();
        }
      }
      ctx.globalAlpha = 1;
      ctx.lineWidth = 1;
    }

    // ── run loop ──
    let raf = 0, running = false, visible = true;

    function loop(t: number) { draw(t); raf = requestAnimationFrame(loop); }
    function start() { if (running || !visible || document.hidden) return; running = true; raf = requestAnimationFrame(loop); }
    function stop()  { running = false; cancelAnimationFrame(raf); }

    if (!reduced) {
      new IntersectionObserver(([e]) => {
        visible = e.isIntersecting;
        visible ? start() : stop();
      }, { threshold: 0.05 }).observe(canvas);
      document.addEventListener('visibilitychange', () => document.hidden ? stop() : start());
      start();
    } else {
      draw(0); // a still marbled print
    }
  })();
</script>
