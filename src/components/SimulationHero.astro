---
---

<div class="hero">
  <canvas class="hero-canvas" id="sim" aria-hidden="true"></canvas>
  <div class="hero-fade" aria-hidden="true"></div>
  <div class="hero-content">
    <div class="hero-text">
      <h1 class="rise"><span id="typed-name">Carey Okal</span><span
          class="type-caret"
          aria-hidden="true"></span></h1>
      <p class="hero-bio rise">
        I'm an MPS student in Information Science at Cornell Bowers CIS (B.S.
        Information Science '26, cum laude), working at the intersection of
        LLMs, social simulation, and data science. At the
        <a href="/research/social-simulation/">Social Dynamics Lab</a> I audit
        multi-agent LLM simulations and built the large-scale ingestion
        pipelines behind persuasion-strategy research on political news.
      </p>
    </div>
    <figure class="hero-fig rise">
      <img
        src="/images/portrait.jpg"
        alt="Carey Okal"
        width="768"
        height="1024"
        fetchpriority="high"
      />
    </figure>
  </div>
</div>

<script>
  // Typewriter
  (() => {
    const el = document.getElementById('typed-name');
    if (!el || matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const name = el.textContent ?? '';
    el.textContent = '';
    const caret = document.querySelector('.type-caret') as HTMLElement | null;
    let at = 0;
    function type() {
      el!.textContent = name.slice(0, ++at);
      if (at < name.length) setTimeout(type, 95 + Math.random() * 70);
      else if (caret) setTimeout(() => caret.classList.add('type-caret--done'), 2100);
    }
    setTimeout(type, 500);
  })();

  // ── Suminagashi rings ─────────────────────────────────────────────────────
  // Concentric hairline rings spread from a few drop points, like ink rings
  // on still water. Each ring undulates slowly; moving the cursor across them
  // drags the lines aside like a stylus through the water, and they relax
  // back. Crisp 1px strokes at low alpha — the same hairline weight the rest
  // of the site is built from. Transparent canvas: the paper shows through.
  (() => {
    const canvas = document.getElementById('sim') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fine = matchMedia('(hover: hover) and (pointer: fine)').matches;
    const animated = !reduced && fine; // touch + reduced-motion get a still print

    // ── sizing ──
    let W = 0, H = 0, dpr = 1;
    function resize() {
      const r = canvas.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = r.width; H = r.height;
      canvas.width  = Math.round(W * dpr);
      canvas.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    let rt: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => { resize(); if (!animated) draw(0); }, 150);
    });

    // ── palette ──
    let ink = '#121216', accent = '#9a1414';
    function readColors() {
      const s = getComputedStyle(document.documentElement);
      ink    = s.getPropertyValue('--ink').trim()    || ink;
      accent = s.getPropertyValue('--accent').trim() || accent;
    }
    readColors();

    // ── drop systems ──
    // Anchors in normalised coords; the main system sits behind the portrait
    // side, two smaller ones balance the corners. The hero-fade quiets
    // whatever passes under the text. Harmonics give each system its own
    // hand-drawn waviness.
    const drops = [
      {
        ax: 0.70, ay: 0.42, gap: 30, rings: 42, accentRing: 7,
        h: [{ k: 3, a: 0.028, p: 1.7 }, { k: 5, a: 0.016, p: 4.2 }],
      },
      {
        ax: 0.16, ay: 0.80, gap: 26, rings: 13, accentRing: 4,
        h: [{ k: 4, a: 0.030, p: 0.6 }, { k: 7, a: 0.014, p: 2.9 }],
      },
      {
        ax: 0.38, ay: 0.10, gap: 24, rings: 9, accentRing: -1,
        h: [{ k: 3, a: 0.026, p: 5.1 }, { k: 6, a: 0.015, p: 1.3 }],
      },
    ];

    // ── stylus impulses ──
    // Each cursor movement leaves a short-lived push in the water.
    // Gaussian in space, exponential decay in time.
    interface Imp { x: number; y: number; dx: number; dy: number; born: number }
    const imps: Imp[] = [];
    const SIGMA = 80, SIG2 = 2 * SIGMA * SIGMA, TAU = 1200, MAX_IMPS = 14;

    let lastX = -1, lastY = -1;
    const hero = canvas.closest('.hero') as HTMLElement | null;
    if (animated && hero) {
      hero.addEventListener('pointermove', (e: PointerEvent) => {
        const r = hero.getBoundingClientRect();
        const x = e.clientX - r.left, y = e.clientY - r.top;
        if (lastX >= 0) {
          let dx = x - lastX, dy = y - lastY;
          const sp = Math.hypot(dx, dy);
          if (sp < 3) return; // ignore micro-jitter
          const cap = Math.min(sp, 22) / sp; // clamp push strength
          dx *= cap * 1.4; dy *= cap * 1.4;
          imps.push({ x, y, dx, dy, born: performance.now() });
          if (imps.length > MAX_IMPS) imps.shift();
        }
        lastX = x; lastY = y;
      }, { passive: true });
      hero.addEventListener('pointerleave', () => { lastX = -1; lastY = -1; });
    }

    // ── draw ──
    function draw(t: number) {
      ctx.clearRect(0, 0, W, H);
      ctx.lineWidth = 1;
      const now = performance.now();

      for (let i = imps.length - 1; i >= 0; i--) {
        if (now - imps[i].born > TAU * 4) imps.splice(i, 1);
      }

      for (const d of drops) {
        const cx = d.ax * W, cy = d.ay * H;

        for (let ri = 1; ri <= d.rings; ri++) {
          const r0 = ri * d.gap;
          const segs = Math.min(220, Math.max(56, (r0 * 0.55) | 0));

          const isAccent = ri === d.accentRing;
          ctx.strokeStyle = isAccent ? accent : ink;
          ctx.globalAlpha = isAccent ? 0.20 : ri % 5 === 0 ? 0.16 : 0.10;

          ctx.beginPath();
          for (let s = 0; s <= segs; s++) {
            const th = (s / segs) * Math.PI * 2;

            // organic waviness + very slow breathing
            let r = r0;
            for (const hm of d.h) {
              r += Math.sin(hm.k * th + hm.p + t * 0.00005 * hm.k) * r0 * hm.a;
            }

            let px = cx + Math.cos(th) * r;
            let py = cy + Math.sin(th) * r;

            // stylus displacement
            for (const im of imps) {
              const ddx = px - im.x, ddy = py - im.y;
              if (ddx > 260 || ddx < -260 || ddy > 260 || ddy < -260) continue;
              const w =
                Math.exp(-(ddx * ddx + ddy * ddy) / SIG2) *
                Math.exp(-(now - im.born) / TAU);
              px += im.dx * w;
              py += im.dy * w;
            }

            s === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
          }
          ctx.stroke();
        }
      }
      ctx.globalAlpha = 1;
    }

    // ── run loop ──
    let raf = 0, running = false, visible = true;

    function loop(t: number) { draw(t); raf = requestAnimationFrame(loop); }
    function start() { if (running || !visible || document.hidden) return; running = true; raf = requestAnimationFrame(loop); }
    function stop()  { running = false; cancelAnimationFrame(raf); }

    if (animated) {
      new IntersectionObserver(([e]) => {
        visible = e.isIntersecting;
        visible ? start() : stop();
      }, { threshold: 0.05 }).observe(canvas);
      document.addEventListener('visibilitychange', () => document.hidden ? stop() : start());
      start();
    } else {
      draw(0); // a still marbled print
    }
  })();
</script>
