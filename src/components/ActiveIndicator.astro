---
interface Props {
  label?: string;
}

const { label = 'Active project' } = Astro.props;
---

<span class="active-indicator" role="status" aria-label={label}>
  <span class="active-indicator__dot" aria-hidden="true"></span>
</span>

<style>
  .active-indicator {
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
    margin-right: 0.35em;
    line-height: 1;
  }

  .active-indicator__dot {
    display: block;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow:
      0 0 0 2px color-mix(in srgb, var(--accent-soft) 55%, transparent),
      0 0 0.55rem color-mix(in srgb, var(--accent) 35%, transparent);
    animation: active-indicator-pulse 2.5s ease-in-out infinite;
  }

  @keyframes active-indicator-pulse {
    0%,
    100% {
      opacity: 0.55;
      box-shadow:
        0 0 0 2px color-mix(in srgb, var(--accent-soft) 40%, transparent),
        0 0 0.35rem color-mix(in srgb, var(--accent) 22%, transparent);
    }
    50% {
      opacity: 1;
      box-shadow:
        0 0 0 3px color-mix(in srgb, var(--accent-soft) 70%, transparent),
        0 0 0.85rem color-mix(in srgb, var(--accent) 48%, transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .active-indicator__dot {
      animation: none;
      opacity: 0.85;
      box-shadow:
        0 0 0 2px color-mix(in srgb, var(--accent-soft) 55%, transparent),
        0 0 0.5rem color-mix(in srgb, var(--accent) 30%, transparent);
    }
  }
</style>
