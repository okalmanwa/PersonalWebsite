---
/**
 * Custom system-architecture diagrams, one per research project.
 * Hand-drawn SVG: monochrome structure, accent for the signal path.
 * "Explains, never decorates."
 */
interface Props {
  id: string;
}
const { id } = Astro.props;
---

{
  id === 'social-simulation' && (
    <svg viewBox="0 0 760 290" role="img" aria-label="System architecture: agents in a Phaser 3 world produce conversation logs and internal traces, audited by regex and LLM pipelines into a consistency report">
      <defs>
        <marker id="arr-a" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="7" markerHeight="7" orient="auto">
          <path d="M0 0L8 4L0 8z" fill="var(--faint)" />
        </marker>
      </defs>
      <g fill="none" stroke="var(--faint)" stroke-width="1.2">
        <rect x="20" y="40" width="220" height="210" rx="5" />
        <rect x="320" y="40" width="170" height="62" rx="5" />
        <rect x="320" y="188" width="170" height="62" rx="5" />
        <rect x="570" y="106" width="170" height="78" rx="5" />
      </g>
      <g font-size="10.5" fill="var(--muted)" letter-spacing="0.08em">
        <text x="32" y="28">PHASER 3 WORLD · REAL TIME</text>
        <text x="332" y="28">AUDIT PIPELINES</text>
        <text x="582" y="94">OUTPUT</text>
      </g>
      <!-- agents inside the world -->
      <g stroke="var(--faint)" stroke-width="1" opacity="0.7">
        <line x1="70" y1="100" x2="130" y2="130" />
        <line x1="130" y1="130" x2="105" y2="190" />
        <line x1="130" y1="130" x2="195" y2="105" />
        <line x1="105" y1="190" x2="180" y2="205" />
      </g>
      <g fill="var(--ink)">
        <circle cx="70" cy="100" r="5" />
        <circle cx="105" cy="190" r="5" />
        <circle cx="195" cy="105" r="5" />
        <circle cx="180" cy="205" r="5" />
      </g>
      <circle cx="130" cy="130" r="6" fill="var(--accent)" />
      <g font-size="10" fill="var(--muted)">
        <text x="32" y="224">autonomous LLM agents</text>
        <text x="32" y="238">memory · relationships</text>
      </g>
      <!-- flows -->
      <g fill="none" stroke="var(--faint)" stroke-width="1.2" marker-end="url(#arr-a)">
        <path d="M240 80 C 280 75, 285 71, 314 71" />
        <path d="M240 210 C 280 215, 285 219, 314 219" />
        <path d="M490 71 C 530 75, 535 110, 564 124" />
        <path d="M490 219 C 530 215, 535 180, 564 166" />
      </g>
      <g font-size="9" fill="var(--accent)">
        <text x="246" y="52">conversation</text>
        <text x="246" y="64">logs</text>
        <text x="250" y="236">internal</text>
        <text x="250" y="248">traces</text>
      </g>
      <g font-size="11.5" fill="var(--ink)" font-weight="500">
        <text x="334" y="66">REGEX SWEEPS</text>
        <text x="334" y="214">LLM-AS-JUDGE</text>
        <text x="584" y="138">GAME-STATE</text>
        <text x="584" y="153">CONSISTENCY</text>
      </g>
      <g font-size="9.5" fill="var(--muted)">
        <text x="334" y="84">structure · timeline</text>
        <text x="334" y="232">character drift</text>
        <text x="584" y="172">flagged violations</text>
      </g>
    </svg>
  )
}

{
  id === 'persuasion-pipeline' && (
    <svg viewBox="0 0 760 200" role="img" aria-label="Pipeline: political news articles from GDELT flow through a resilient scraper and validation into LLM classification and a strategy taxonomy">
      <defs>
        <marker id="arr-b" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="7" markerHeight="7" orient="auto">
          <path d="M0 0L8 4L0 8z" fill="var(--faint)" />
        </marker>
      </defs>
      <g fill="none" stroke="var(--faint)" stroke-width="1.2">
        <rect x="16" y="60" width="120" height="70" rx="5" />
        <rect x="186" y="60" width="140" height="70" rx="5" stroke="var(--accent)" />
        <rect x="376" y="60" width="120" height="70" rx="5" />
        <rect x="546" y="60" width="100" height="70" rx="5" />
        <rect x="686" y="40" width="58" height="110" rx="5" />
      </g>
      <g fill="none" stroke="var(--faint)" stroke-width="1.2" marker-end="url(#arr-b)">
        <line x1="136" y1="95" x2="180" y2="95" />
        <line x1="326" y1="95" x2="370" y2="95" />
        <line x1="496" y1="95" x2="540" y2="95" />
        <line x1="646" y1="95" x2="680" y2="95" />
      </g>
      <g font-size="11.5" fill="var(--ink)" font-weight="500">
        <text x="28" y="86">GDELT</text>
        <text x="198" y="86">SCRAPER</text>
        <text x="388" y="86">VALIDATE</text>
        <text x="558" y="86">LLM FT</text>
      </g>
      <g font-size="9.5" fill="var(--muted)">
        <text x="28" y="104">political news</text>
        <text x="28" y="117">across domains</text>
        <text x="198" y="104">concurrent · resumable</text>
        <text x="198" y="117">retry · open source</text>
        <text x="388" y="104">paywalls · 404s</text>
        <text x="388" y="117">boilerplate</text>
        <text x="558" y="104">fine-tune &amp;</text>
        <text x="558" y="117">evaluate</text>
        <text x="686" y="30">STRATEGY MIX</text>
      </g>
      <!-- taxonomy mini-distribution -->
      <g fill="var(--accent)">
        <rect x="694" y="60" width="42" height="8" rx="2" opacity="0.9" />
        <rect x="694" y="76" width="30" height="8" rx="2" opacity="0.65" />
        <rect x="694" y="92" width="22" height="8" rx="2" opacity="0.45" />
        <rect x="694" y="108" width="14" height="8" rx="2" opacity="0.3" />
        <rect x="694" y="124" width="9" height="8" rx="2" opacity="0.2" />
      </g>
      <text x="186" y="48" font-size="10" fill="var(--accent)" letter-spacing="0.08em">WHAT I BUILT</text>
    </svg>
  )
}

{
  id === 'disaster-resilience' && (
    <svg viewBox="0 0 760 260" role="img" aria-label="Multi-modal fusion: CDR, satellite imagery, and survey data fuse into features feeding predictive models that become policy narratives">
      <defs>
        <marker id="arr-c" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="7" markerHeight="7" orient="auto">
          <path d="M0 0L8 4L0 8z" fill="var(--faint)" />
        </marker>
      </defs>
      <g fill="none" stroke="var(--faint)" stroke-width="1.2">
        <rect x="16" y="20" width="150" height="56" rx="5" />
        <rect x="16" y="100" width="150" height="56" rx="5" />
        <rect x="16" y="180" width="150" height="56" rx="5" />
        <rect x="246" y="100" width="150" height="56" rx="5" />
        <rect x="476" y="100" width="120" height="56" rx="5" />
        <rect x="646" y="80" width="100" height="96" rx="5" stroke="var(--accent)" />
      </g>
      <g fill="none" stroke="var(--faint)" stroke-width="1.2" marker-end="url(#arr-c)">
        <path d="M166 48 C 210 55, 215 95, 240 112" />
        <line x1="166" y1="128" x2="240" y2="128" />
        <path d="M166 208 C 210 201, 215 161, 240 144" />
        <line x1="396" y1="128" x2="470" y2="128" />
        <line x1="596" y1="128" x2="640" y2="128" />
      </g>
      <g font-size="11.5" fill="var(--ink)" font-weight="500">
        <text x="28" y="42">CDR</text>
        <text x="28" y="122">SATELLITE</text>
        <text x="28" y="202">SURVEYS</text>
        <text x="258" y="122">FEATURE FUSION</text>
        <text x="488" y="122">MODELS</text>
        <text x="658" y="112">POLICY</text>
      </g>
      <g font-size="9.5" fill="var(--muted)">
        <text x="28" y="60">mobility · displacement</text>
        <text x="28" y="140">environmental stress</text>
        <text x="28" y="220">ground vulnerability</text>
        <text x="258" y="140">time · space · units</text>
        <text x="488" y="140">early warning</text>
        <text x="658" y="130">narratives →</text>
        <text x="658" y="144">funders &amp;</text>
        <text x="658" y="158">responders</text>
      </g>
      <text x="646" y="68" font-size="10" fill="var(--accent)" letter-spacing="0.08em">MY FOCUS</text>
    </svg>
  )
}

{
  id === 'ecotourism-platform' && (
    <svg viewBox="0 0 760 230" role="img" aria-label="The Community Tourism Relay connects the Il Ngwesi community to travelers and buyers through bookings and the Maasai Marketplace, with a community portal for revenue and listings">
      <defs>
        <marker id="arr-d" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="7" markerHeight="7" orient="auto">
          <path d="M0 0L8 4L0 8z" fill="var(--faint)" />
        </marker>
      </defs>
      <g fill="none" stroke="var(--faint)" stroke-width="1.2">
        <rect x="16" y="40" width="180" height="110" rx="5" />
        <rect x="286" y="40" width="190" height="110" rx="5" stroke="var(--accent)" />
        <rect x="566" y="40" width="178" height="110" rx="5" />
      </g>
      <g fill="none" stroke="var(--faint)" stroke-width="1.2" marker-end="url(#arr-d)">
        <line x1="196" y1="95" x2="280" y2="95" />
        <line x1="476" y1="95" x2="560" y2="95" />
      </g>
      <g font-size="11.5" fill="var(--ink)" font-weight="500">
        <text x="28" y="64">COMMUNITY</text>
        <text x="298" y="64">TOURISM RELAY</text>
        <text x="578" y="64">TRAVELERS &amp; BUYERS</text>
      </g>
      <g font-size="9.5" fill="var(--muted)">
        <text x="28" y="84">Maasai-owned conservancy</text>
        <text x="28" y="98">lodge · homestays · guides</text>
        <text x="28" y="112">artisans &amp; merchants</text>
        <text x="298" y="84">bookings · SMS steward</text>
        <text x="298" y="112">M-Pesa · card · PayPal</text>
        <text x="578" y="84">book experiences</text>
        <text x="578" y="98">buy handmade goods</text>
      </g>
      <text x="298" y="98" font-size="9.5" fill="var(--accent)">Maasai Marketplace · shop</text>
      <g font-size="9.5" fill="var(--muted)">
        <text x="16" y="190">PARTNERS · USIU-Africa Chandaria Business School · Northern Rangelands Trust · Ecotourism Kenya</text>
        <text x="16" y="212" fill="var(--accent)">TOP SOLUTION AMONG 5 MULTI-INSTITUTIONAL TEAMS</text>
      </g>
    </svg>
  )
}
