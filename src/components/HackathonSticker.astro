---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { size = 'md', class: className = '' } = Astro.props;
---

<span
  class:list={['hackathon-sticker', `hackathon-sticker--${size}`, className]}
  role="img"
  aria-label="Hackathon winner"
>
  <svg
    class="hackathon-sticker__svg"
    viewBox="0 0 120 120"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="sticker-gold" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#f5d76e" />
        <stop offset="45%" stop-color="#d4a72c" />
        <stop offset="100%" stop-color="#9a6f1a" />
      </linearGradient>
      <filter id="sticker-shadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="2" stdDeviation="2" flood-color="#1a1208" flood-opacity="0.22" />
      </filter>
    </defs>
    <g filter="url(#sticker-shadow)">
      <circle cx="60" cy="60" r="52" fill="url(#sticker-gold)" stroke="#8b6914" stroke-width="2.5" />
      <circle cx="60" cy="60" r="44" fill="none" stroke="#fff8e6" stroke-width="1.5" opacity="0.55" />
      <path
        d="M60 18 L66 38 L88 38 L70 50 L76 70 L60 58 L44 70 L50 50 L32 38 L54 38 Z"
        fill="#fff8e6"
        stroke="#8b6914"
        stroke-width="1.2"
        stroke-linejoin="round"
      />
    </g>
  </svg>
  <span class="hackathon-sticker__label">
    <span class="hackathon-sticker__line">Hackathon</span>
    <span class="hackathon-sticker__line hackathon-sticker__line--winner">Winner</span>
  </span>
</span>

<style>
  .hackathon-sticker {
    --sticker-size: 4.5rem;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    transform: rotate(-6deg);
    filter: drop-shadow(0 4px 10px rgba(26, 18, 8, 0.18));
  }

  .hackathon-sticker--sm {
    --sticker-size: 3.25rem;
    gap: 0.2rem;
  }

  .hackathon-sticker--lg {
    --sticker-size: 5.5rem;
    gap: 0.45rem;
  }

  .hackathon-sticker__svg {
    width: var(--sticker-size);
    height: var(--sticker-size);
  }

  .hackathon-sticker__label {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.15;
    color: #8b6914;
    background: linear-gradient(135deg, #fff8e6 0%, #f5e6b8 100%);
    border: 1.5px solid #c9a227;
    border-radius: 4px;
    padding: 0.2em 0.55em;
    box-shadow: 0 2px 0 #b8922a;
  }

  .hackathon-sticker--sm .hackathon-sticker__label {
    font-size: 0.5rem;
    padding: 0.15em 0.4em;
  }

  .hackathon-sticker--lg .hackathon-sticker__label {
    font-size: 0.65rem;
  }

  .hackathon-sticker__line--winner {
    color: #6b4f0f;
    font-weight: 700;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hackathon-sticker {
      animation: sticker-wiggle 4s ease-in-out infinite;
    }
  }

  @keyframes sticker-wiggle {
    0%,
    88%,
    100% {
      transform: rotate(-6deg) scale(1);
    }
    92% {
      transform: rotate(-4deg) scale(1.03);
    }
    96% {
      transform: rotate(-7deg) scale(1.01);
    }
  }
</style>
