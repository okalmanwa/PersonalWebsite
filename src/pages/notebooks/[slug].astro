---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { notebooks } from '../../data/notebooks';

export function getStaticPaths() {
  return notebooks.map((notebook) => ({
    params: { slug: notebook.slug },
    props: { notebook },
  }));
}

const { notebook } = Astro.props;
const notebookUrl = new URL(`/notebooks/${notebook.file}`, Astro.site).href;
const nbviewerUrl = `https://nbviewer.org/format/url/${encodeURIComponent(notebookUrl)}`;
const downloadUrl = `/notebooks/${notebook.file}`;
---

<BaseLayout
  title={`${notebook.title} · Carey Okal`}
  description={notebook.blurb}
>
  <article class="notebook-page col">
    <header class="notebook-header">
      <a class="back-link" href="/#scratch-builds">← Built from scratch</a>
      <span class="eyebrow">{notebook.stack}</span>
      <h1 style="font-size: var(--text-2xl);">{notebook.title}</h1>
      <p class="abstract">{notebook.blurb}</p>
      <div class="notebook-actions">
        <a class="btn" href={nbviewerUrl} target="_blank" rel="noopener">
          Open in nbviewer <span class="arrow">↗</span>
        </a>
        <a class="btn btn--ghost" href={downloadUrl} download>
          Download .ipynb <span class="arrow">↓</span>
        </a>
      </div>
    </header>

    <div class="notebook-frame reveal">
      <iframe
        src={nbviewerUrl}
        title={`${notebook.title} notebook`}
        loading="lazy"
        sandbox="allow-scripts allow-same-origin allow-popups"
      ></iframe>
    </div>
  </article>
</BaseLayout>
