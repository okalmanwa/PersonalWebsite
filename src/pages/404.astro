---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 · Carey Manwa" description="Page not found.">
  <div class="lost col">
    <div>
      <p class="code">ERROR 404 · AGENT NOT FOUND</p>
      <h1 style="font-size: var(--text-2xl);">This page wandered off the map.</h1>
      <p style="color: var(--muted);">
        Like an agent that broke character, this URL references a state that
        doesn't exist.
      </p>
      <a class="read-more" href="/">Return to the simulation <span class="arrow">→</span></a>
    </div>
  </div>
</BaseLayout>
