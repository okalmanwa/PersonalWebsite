---
import BaseLayout from '../layouts/BaseLayout.astro';

const courses = [
  {
    tag: 'ORIE 3120',
    title: 'Course Assistant · Practical Tools for OR, ML & Data Science',
    org: 'Cornell Engineering',
    body: `Cornell's applied data science core for engineers. I support students
      across SQL and Python for data work, Tableau for communication, and
      the modeling sequence of regression, classification, time-series
      forecasting, and A/B testing. Most of the course comes down to
      judgment about which method answers which question.`,
    chips: ['SQL', 'Python', 'Tableau', 'Regression', 'Classification', 'Time series', 'A/B testing'],
  },
  {
    tag: 'INFO 2950',
    title: 'Teaching Assistant · Introduction to Data Science',
    org: 'Cornell Bowers CIS',
    body: `An introductory data science course with roughly 300 students a
      semester, many of them writing their first real code. I work with
      students on Python, statistical analysis, and building the confidence
      to debug their own work.`,
    chips: ['Python', 'Regression', 'Hypothesis testing', 'Data visualization'],
  },
  {
    tag: 'INFO 1300',
    title: 'Teaching Assistant · Introductory Design & Programming for the Web',
    org: 'Cornell Bowers CIS',
    body: `An introductory course where students design and ship their first
      accessible websites, from markup to UX. Across three consecutive
      semesters as a TA for these two courses, students rated me a perfect
      10/10 in TA evaluations.`,
    chips: ['HTML', 'CSS', 'JavaScript', 'UX design', 'Accessibility'],
  },
];
---

<BaseLayout
  title="Teaching · Carey Okal"
  description="Teaching at Cornell: ORIE 3120 course assistant, and Bowers CIS TA for INFO 2950 and INFO 1300 with perfect 10/10 TA evaluations across three consecutive semesters."
>
  <div class="col">
    <header class="article-header">
      <span class="eyebrow">Teaching<span class="dot">·</span>Cornell University</span>
      <h1>Teaching</h1>
    </header>

    {
      courses.map((c) => (
        <section class="course reveal">
          <span class="course-tag">{c.tag}</span>
          <h2>{c.title}</h2>
          <span class="eyebrow">{c.org}</span>
          <p>{c.body}</p>
          <ul class="topic-chips" aria-label="Topics covered">
            {c.chips.map((chip) => (
              <li>{chip}</li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</BaseLayout>
