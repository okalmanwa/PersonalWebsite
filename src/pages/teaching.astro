---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/article.css';
import '../styles/teaching.css';

const courses = [
  {
    code: 'ORIE 3120',
    dept: 'orie',
    role: 'Course Assistant',
    title: 'Practical Tools for OR, ML & Data Science',
    org: 'Cornell Engineering',
    body: `Cornell's applied data science core for engineers. I support students
      across SQL and Python for data work, Tableau for communication, and
      the modeling sequence of regression, classification, time-series
      forecasting, and A/B testing. Most of the course comes down to
      judgment about which method answers which question.`,
    chips: ['SQL', 'Python', 'Tableau', 'Regression', 'Classification', 'Time series', 'A/B testing'],
  },
  {
    code: 'INFO 2950',
    dept: 'info',
    role: 'Teaching Assistant',
    title: 'Introduction to Data Science',
    org: 'Cornell Bowers CIS',
    body: `An introductory data science course with roughly 300 students a
      semester, many of them writing their first real code. I work with
      students on Python, statistical analysis, and building the confidence
      to debug their own work.`,
    chips: ['Python', 'Regression', 'Hypothesis testing', 'Data visualization'],
  },
  {
    code: 'INFO 1300',
    dept: 'info',
    role: 'Teaching Assistant',
    title: 'Introductory Design & Programming for the Web',
    org: 'Cornell Bowers CIS',
    body: `An introductory course where students design and ship their first
      accessible websites, from markup to UX. I led weekly recitation
      sections, held office hours, and graded exams and projects, providing
      timely feedback.`,
    chips: ['HTML', 'CSS', 'JavaScript', 'UX design', 'Accessibility'],
  },
];

function roleVariant(role: string) {
  return /course assistant/i.test(role) ? 'role-pill--lead' : 'role-pill--ta';
}
---

<BaseLayout
  title="Teaching · Carey Okal"
  description="Teaching at Cornell: ORIE 3120 course assistant, and Bowers CIS TA for INFO 2950 and INFO 1300, leading weekly recitations, holding office hours, and grading exams and projects."
>
  <article class="col teaching-page">
    <header class="article-header teaching-header reveal">
      <span class="eyebrow">Cornell University</span>
      <h1>Teaching</h1>
    </header>

    <ol class="course-list">
      {
        courses.map((c) => (
          <li class="course reveal">
            <div class="course-meta">
              <span class="entry-index" aria-hidden="true" />
              <span class:list={['course-code', `course-code--${c.dept}`]}>
                {c.code}
              </span>
              <span class:list={['role-pill', roleVariant(c.role)]}>
                {c.role}
              </span>
              <span class="course-org">{c.org}</span>
            </div>
            <h2>{c.title}</h2>
            <p class="course-body">{c.body}</p>
            <ul class="course-chips" aria-label="Topics covered">
              {c.chips.map((chip) => (
                <li>{chip}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>
  </article>
</BaseLayout>
