---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SimulationHero from '../components/SimulationHero.astro';

const research = (await getCollection('research'))
  .filter((e) => e.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout>
  <SimulationHero />

  <section class="section wide" aria-labelledby="featured">
    <div class="section-head reveal">
      <span class="eyebrow" id="featured">Selected research</span>
      <a class="all-link" href="/research/">ALL PROJECTS →</a>
    </div>
    <ol class="entry-list">
      {
        research.map((p) => (
          <li class="entry reveal">
            <span class="eyebrow">
              {p.data.lab}
              <span class="dot">·</span>
              {p.data.dates}
              <span class="dot">·</span>
              {p.data.status}
            </span>
            <h3>
              <a href={`/research/${p.id}/`}>{p.data.title}</a>
            </h3>
            <p class="abstract">{p.data.abstract}</p>
            <a class="read-more" href={`/research/${p.id}/`}>
              Read more <span class="arrow">→</span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="section col reveal" aria-labelledby="bio">
    <span class="eyebrow" id="bio">In brief</span>
    <p>
      I'm a graduate student at Cornell working at the intersection of LLMs,
      social simulation, and development economics. At the
      <a href="/research/social-simulation/">Social Dynamics Lab</a> I audit
      multi-agent LLM simulations and classify persuasion strategies across 2M+
      news articles; at <a href="/research/disaster-resilience/">CIDER</a> I
      help build predictive systems for disaster resilience. Before Cornell, I worked
      with EducationUSA in Nairobi, reaching 20,000+ students across 30+
      Kenyan high schools.
    </p>
  </section>

  <section class="section wide" aria-labelledby="side-projects">
    <div class="section-head reveal">
      <span class="eyebrow" id="side-projects">Side projects</span>
    </div>
    <ul class="mini-list">
      <li class="mini reveal">
        <a href="https://www.mathmentor.academy/" target="_blank" rel="noopener"
          >MathMentor <span class="ext">↗</span></a
        >
        <p>A RAG-powered AI math tutoring platform.</p>
      </li>
      <li class="mini reveal">
        <a
          href="https://chromewebstore.google.com/detail/block-ai-overview/bmlfocmlnojabbielkcelpallkfpljba"
          target="_blank"
          rel="noopener">Block AI Overview <span class="ext">↗</span></a
        >
        <p>
          A Chrome extension that rewrites Google searches to skip AI
          Overviews, without touching the page DOM.
        </p>
      </li>
      <li class="mini reveal">
        <a
          href="https://cidercornell.github.io/neudc2026/"
          target="_blank"
          rel="noopener">NEUDC 2026 <span class="ext">↗</span></a
        >
        <p>
          Site for the longest-running development economics conference,
          hosted at Cornell in November 2026.
        </p>
      </li>
      <li class="mini reveal">
        <a
          href="https://famous-lamington-f4a918.netlify.app/"
          target="_blank"
          rel="noopener">SMART Student Blog <span class="ext">↗</span></a
        >
        <p>
          A blog platform for Cornell's SMART Program, with accounts, posts,
          and project filtering.
        </p>
      </li>
    </ul>
  </section>

  <section class="contact-block wide reveal" aria-labelledby="contact">
    <span class="eyebrow" id="contact">Contact</span>
    <p style="max-width: 40ch;">
      Open to research collaborations, PhD conversations, and hard data
      problems.
    </p>
    <a class="btn" href="mailto:careyokal@gmail.com"
      >Email me <span class="arrow">→</span></a
    >
  </section>
</BaseLayout>
