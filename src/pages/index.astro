---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SimulationHero from '../components/SimulationHero.astro';
import { visuals } from '../data/visuals';

const research = (await getCollection('research')).sort(
  (a, b) => a.data.order - b.data.order
);

const projects = [
  {
    name: 'MathMentor',
    url: 'https://www.mathmentor.academy/',
    domain: 'mathmentor.academy',
    img: '/images/projects/mathmentor.jpg',
    alt: 'MathMentor landing page: train your own AI teaching assistants, with a live tutoring demo',
    desc: 'A RAG-powered AI math tutoring platform.',
  },
  {
    name: 'Block AI Overview',
    url: 'https://chromewebstore.google.com/detail/block-ai-overview/bmlfocmlnojabbielkcelpallkfpljba',
    domain: 'chromewebstore.google.com',
    img: '/images/projects/block-ai-overview.jpg',
    alt: 'Block AI Overview rewriting a Google search to skip the AI Overview',
    desc: 'A Chrome extension that rewrites Google searches to skip AI Overviews, without touching the page DOM.',
  },
  {
    name: 'NEUDC 2026',
    url: 'https://cidercornell.github.io/neudc2026/',
    domain: 'cidercornell.github.io',
    img: '/images/projects/neudc2026.jpg',
    alt: "NEUDC 2026 conference site with Cornell's McGraw Tower in autumn",
    desc: 'Site for the longest-running development economics conference, hosted at Cornell in November 2026.',
  },
  {
    name: 'Cornell CIDER',
    url: 'https://business.cornell.edu/centers/cider/',
    domain: 'business.cornell.edu',
    img: '/images/projects/cider.jpg',
    alt: 'Cornell CIDER website with a savanna sunset hero image',
    desc: 'Web presence of the Collaboration for International Development Economics Research, which I maintain as webmaster.',
  },
  {
    name: 'Missing Voices Kenya',
    url: 'https://okalmanwa.github.io/killingsKE/',
    domain: 'okalmanwa.github.io',
    img: '/images/projects/missing-voices.jpg',
    alt: 'Missing Voices Kenya: interactive map of police killings with county and year filters',
    desc: 'An interactive map documenting police killings and extrajudicial executions in Kenya, filterable by county and year.',
  },
];
---

<BaseLayout>
  <SimulationHero />

  <section class="section wide" aria-labelledby="research">
    <div class="section-head reveal">
      <span class="eyebrow" id="research">Research</span>
    </div>
    <ol class="entry-list">
      {
        research.map((p) => (
          <li class="entry entry--visual reveal">
            <div class="entry-body">
              <span class="eyebrow">
                {p.data.lab}
                <span class="dot">·</span>
                {p.data.dates}
                <span class="dot">·</span>
                {p.data.status}
              </span>
              <h3>
                <a href={`/research/${p.id}/`}>{p.data.title}</a>
              </h3>
              <p class="abstract">{p.data.abstract}</p>
              <span class="entry-links">
                <a class="read-more" href={`/research/${p.id}/`}>
                  Read more <span class="arrow">→</span>
                </a>
                {p.data.links?.map((l) => (
                  <a class="read-more" href={l.url} target="_blank" rel="noopener">
                    {l.label} <span class="arrow">↗</span>
                  </a>
                ))}
              </span>
            </div>
            {
              visuals[p.id] && (
                <a
                  class="entry-visual"
                  href={`/research/${p.id}/`}
                  tabindex="-1"
                  aria-hidden="true"
                >
                  <img
                    src={visuals[p.id].src}
                    alt={visuals[p.id].alt}
                    loading="lazy"
                    width="400"
                    height="300"
                    style={visuals[p.id].pos ? `object-position: ${visuals[p.id].pos}` : undefined}
                  />
                </a>
              )
            }
          </li>
        ))
      }
    </ol>
  </section>

  <section class="section wide" aria-labelledby="side-projects">
    <div class="section-head reveal">
      <span class="eyebrow" id="side-projects">Side projects</span>
    </div>
    <p class="section-lede reveal">
      Research aside, I build for the web: client work and my own products,
      all currently live.
    </p>
    <ul class="project-grid">
      {
        projects.map((p, idx) => (
          <li class={`reveal${idx === 0 ? ' project-feature' : ''}`}>
            <a class="project-card" href={p.url} target="_blank" rel="noopener">
              <span class="browser">
                <span class="browser-bar" aria-hidden="true">
                  <span class="b-dots">
                    <i />
                    <i />
                    <i />
                  </span>
                  <span class="b-url">{p.domain}</span>
                  <span class="b-live">
                    <i />
                    LIVE
                  </span>
                </span>
                <img
                  src={p.img}
                  alt={p.alt}
                  loading="lazy"
                  width="500"
                  height="312"
                />
              </span>
              <span class="project-meta">
                <span class="project-index" aria-hidden="true">
                  {String(idx + 1).padStart(2, '0')}
                </span>
                <span class="project-text">
                  <span class="project-name">
                    {p.name} <span class="ext" aria-hidden="true">↗</span>
                  </span>
                  <span class="project-desc">{p.desc}</span>
                </span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
    <p class="section-lede reveal" style="margin-top: var(--space-4);">
      More scrapers, data pipelines, and experiments on
      <a href="https://github.com/okalmanwa" target="_blank" rel="noopener">GitHub ↗</a>.
    </p>
  </section>

  <section class="contact-block wide reveal" aria-labelledby="contact">
    <span class="eyebrow" id="contact">Contact</span>
    <p style="max-width: 40ch;">
      Open to research collaborations, PhD conversations, and hard data
      problems.
    </p>
    <a class="btn" href="mailto:careyokal@gmail.com"
      >Email me <span class="arrow">→</span></a
    >
  </section>
</BaseLayout>

<script>
  // side projects: the browser windows tilt toward the cursor
  (() => {
    const fine =
      matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!fine) return;

    document.querySelectorAll('.project-card').forEach((card) => {
      const browser = card.querySelector('.browser') as HTMLElement | null;
      if (!browser) return;

      card.addEventListener('pointermove', (e) => {
        const r = browser.getBoundingClientRect();
        const px = ((e as PointerEvent).clientX - r.left) / r.width - 0.5;
        const py = ((e as PointerEvent).clientY - r.top) / r.height - 0.5;
        browser.style.transition = 'transform 0.12s ease-out';
        browser.style.transform = `perspective(900px) translateY(-7px) rotateX(${(-py * 7).toFixed(2)}deg) rotateY(${(px * 9).toFixed(2)}deg)`;
      });

      card.addEventListener('pointerleave', () => {
        browser.style.transition = '';
        browser.style.transform = '';
      });
    });
  })();
</script>
