---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SimulationHero from '../components/SimulationHero.astro';
import { visuals } from '../data/visuals';

const research = (await getCollection('research')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout>
  <SimulationHero />

  <section class="section wide reveal" aria-labelledby="bio">
    <span class="eyebrow" id="bio">In brief</span>
    <p class="bio-lede">
      I'm an MPS student in Information Science at Cornell Bowers CIS (B.S.
      Information Science '26, cum laude), working at the intersection of LLMs,
      social simulation, and development economics. At the
      <a href="/research/social-simulation/">Social Dynamics Lab</a> I audit
      multi-agent LLM simulations and built the large-scale ingestion pipelines
      behind persuasion-strategy research on political news; at
      <a href="/research/disaster-resilience/">CIDER</a> I'm
      co-authoring a white paper on predictive systems for disaster resilience. Before Cornell, I worked
      with EducationUSA in Nairobi, reaching 20,000 students across 30
      Kenyan high schools.
    </p>
  </section>

  <section class="section wide" aria-labelledby="research">
    <div class="section-head reveal">
      <span class="eyebrow" id="research">Research</span>
    </div>
    <ol class="entry-list">
      {
        research.map((p) => (
          <li class="entry entry--visual reveal">
            <div class="entry-body">
              <span class="eyebrow">
                {p.data.lab}
                <span class="dot">·</span>
                {p.data.dates}
                <span class="dot">·</span>
                {p.data.status}
              </span>
              <h3>
                <a href={`/research/${p.id}/`}>{p.data.title}</a>
              </h3>
              <p class="abstract">{p.data.abstract}</p>
              <span class="entry-links">
                <a class="read-more" href={`/research/${p.id}/`}>
                  Read more <span class="arrow">→</span>
                </a>
                {p.data.links?.map((l) => (
                  <a class="read-more" href={l.url} target="_blank" rel="noopener">
                    {l.label} <span class="arrow">↗</span>
                  </a>
                ))}
              </span>
            </div>
            {
              visuals[p.id] && (
                <a
                  class="entry-visual"
                  href={`/research/${p.id}/`}
                  tabindex="-1"
                  aria-hidden="true"
                >
                  <img
                    src={visuals[p.id].src}
                    alt={visuals[p.id].alt}
                    loading="lazy"
                    width="400"
                    height="300"
                    style={visuals[p.id].pos ? `object-position: ${visuals[p.id].pos}` : undefined}
                  />
                </a>
              )
            }
          </li>
        ))
      }
    </ol>
  </section>

  <section class="section wide" aria-labelledby="side-projects">
    <div class="section-head reveal">
      <span class="eyebrow" id="side-projects">Side projects</span>
    </div>
    <p class="section-lede reveal">
      Research aside, I build for the web — client work and my own products,
      all currently live.
    </p>
    <ul class="project-grid">
      <li class="reveal">
        <a
          class="project-card"
          href="https://www.mathmentor.academy/"
          target="_blank"
          rel="noopener"
        >
          <span class="project-shot">
            <img
              src="/images/projects/mathmentor.jpg"
              alt="MathMentor landing page: train your own AI teaching assistants, with a live tutoring demo"
              loading="lazy"
              width="500"
              height="312"
            />
          </span>
          <span class="project-name">MathMentor <span class="ext" aria-hidden="true">↗</span></span>
          <span class="project-desc">A RAG-powered AI math tutoring platform.</span>
        </a>
      </li>
      <li class="reveal">
        <a
          class="project-card"
          href="https://chromewebstore.google.com/detail/block-ai-overview/bmlfocmlnojabbielkcelpallkfpljba"
          target="_blank"
          rel="noopener"
        >
          <span class="project-shot">
            <img
              src="/images/projects/block-ai-overview.jpg"
              alt="Block AI Overview rewriting a Google search to skip the AI Overview"
              loading="lazy"
              width="500"
              height="312"
            />
          </span>
          <span class="project-name">Block AI Overview <span class="ext" aria-hidden="true">↗</span></span>
          <span class="project-desc">
            A Chrome extension that rewrites Google searches to skip AI
            Overviews, without touching the page DOM.
          </span>
        </a>
      </li>
      <li class="reveal">
        <a
          class="project-card"
          href="https://cidercornell.github.io/neudc2026/"
          target="_blank"
          rel="noopener"
        >
          <span class="project-shot">
            <img
              src="/images/projects/neudc2026.jpg"
              alt="NEUDC 2026 conference site with Cornell's McGraw Tower in autumn"
              loading="lazy"
              width="500"
              height="312"
            />
          </span>
          <span class="project-name">NEUDC 2026 <span class="ext" aria-hidden="true">↗</span></span>
          <span class="project-desc">
            Site for the longest-running development economics conference,
            hosted at Cornell in November 2026.
          </span>
        </a>
      </li>
      <li class="reveal">
        <a
          class="project-card"
          href="https://business.cornell.edu/centers/cider/"
          target="_blank"
          rel="noopener"
        >
          <span class="project-shot">
            <img
              src="/images/projects/cider.jpg"
              alt="Cornell CIDER website with a savanna sunset hero image"
              loading="lazy"
              width="500"
              height="312"
            />
          </span>
          <span class="project-name">Cornell CIDER <span class="ext" aria-hidden="true">↗</span></span>
          <span class="project-desc">
            Web presence of the Collaboration for International Development
            Economics Research, which I maintain as webmaster.
          </span>
        </a>
      </li>
      <li class="reveal">
        <a
          class="project-card"
          href="https://okalmanwa.github.io/killingsKE/"
          target="_blank"
          rel="noopener"
        >
          <span class="project-shot">
            <img
              src="/images/projects/missing-voices.jpg"
              alt="Missing Voices Kenya: interactive map of police killings with county and year filters"
              loading="lazy"
              width="500"
              height="312"
            />
          </span>
          <span class="project-name">Missing Voices Kenya <span class="ext" aria-hidden="true">↗</span></span>
          <span class="project-desc">
            An interactive map documenting police killings and extrajudicial
            executions in Kenya, filterable by county and year.
          </span>
        </a>
      </li>
    </ul>
    <p class="section-lede reveal" style="margin-top: var(--space-4);">
      More — scrapers, data pipelines, and experiments — on
      <a href="https://github.com/okalmanwa" target="_blank" rel="noopener">GitHub ↗</a>.
    </p>
  </section>

  <section class="contact-block wide reveal" aria-labelledby="contact">
    <span class="eyebrow" id="contact">Contact</span>
    <p style="max-width: 40ch;">
      Open to research collaborations, PhD conversations, and hard data
      problems.
    </p>
    <a class="btn" href="mailto:careyokal@gmail.com"
      >Email me <span class="arrow">→</span></a
    >
  </section>
</BaseLayout>
