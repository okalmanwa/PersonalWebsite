---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Diagram from '../../components/Diagram.astro';

export async function getStaticPaths() {
  const research = await getCollection('research');
  return research.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: d.title,
  abstract: d.abstract,
  author: {
    '@type': 'Person',
    name: 'Carey Okal',
    affiliation: { '@type': 'CollegeOrUniversity', name: 'Cornell University' },
  },
  creativeWorkStatus: d.status,
  url: new URL(`/research/${entry.id}/`, Astro.site).href,
};
---

<BaseLayout title={`${d.title} · Carey Okal`} description={d.abstract} jsonLd={articleLd}>
  <article>
    <header class="article-header col">
      <span class="eyebrow">
        {d.lab}<span class="dot">·</span>{d.dates}<span class="dot">·</span>{d.status}
      </span>
      <h1 style="font-size: var(--text-2xl);">{d.title}</h1>
      <p class="abstract">{d.abstract}</p>

      <dl class="meta-block">
        <dt>Status</dt>
        <dd><span class="status-pill">{d.status}</span></dd>
        <dt>Methods</dt>
        <dd>
          <ul class="topic-chips">
            {d.methods.map((m) => (
              <li>{m}</li>
            ))}
          </ul>
        </dd>
        {d.stack.length > 0 && (
          <>
            <dt>Stack</dt>
            <dd>
              <ul class="topic-chips">
                {d.stack.map((s) => (
                  <li>{s}</li>
                ))}
              </ul>
            </dd>
          </>
        )}
      </dl>
    </header>


    {
      d.diagramCaption && (
        <figure class="figure-wide reveal">
          <div class="diagram">
            <Diagram id={entry.id} />
          </div>
          <figcaption>{d.diagramCaption}</figcaption>
        </figure>
      )
    }

    <div class="article-body col">
      <Content />
    </div>

    <footer class="article-footer col">
      <nav class="article-links" aria-label="Project links">
        <a class="read-more" href="/#research">
          <span class="arrow" style="transform: rotate(180deg);">→</span> All research
        </a>
        {d.links.map((l) => (
          <a class="read-more" href={l.url} target="_blank" rel="noopener">
            {l.label} <span class="arrow">↗</span>
          </a>
        ))}
        <a class="read-more" href="mailto:careyokal@gmail.com">
          Ask me about this <span class="arrow">→</span>
        </a>
      </nav>
    </footer>
  </article>
</BaseLayout>
